#: blackswan-block-external-request.php:332
msgid ""
"Background requests made by WordPress, plugins, and themes via PHP (e.g. update "
"checks, license verification, REST API calls). They happen on the server and are "
"invisible to the browser."
msgstr ""
"درخواست‌های پس‌زمینه‌ای که وردپرس، افزونه‌ها و قالب‌ها از طریق PHP انجام می‌دهند "
"(مانند بررسی به‌روزرسانی، تأیید مجوز، فراخوانی REST API). این درخواست‌ها در سمت "
"سرور اجرا شده و برای مرورگر قابل مشاهده نیستند."

#: blackswan-block-external-request.php:337
msgid "Blacklist (Blocked Domains)"
msgstr "فهرست سیاه (دامنه‌های مسدودشده)"

#: blackswan-block-external-request.php:342
msgid "e.g. example.com"
msgstr "برای مثال: example.com"

