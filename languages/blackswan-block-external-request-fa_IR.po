#: blackswan-block-external-request.php:704 blackswan-block-external-request.php:729
#: blackswan-block-external-request.php:822 blackswan-block-external-request.php:863
msgid "Delete All"
msgstr "حذف همه"

#: blackswan-block-external-request.php:710
msgid "Whitelist (Allowed URL Patterns)"
msgstr "لیست سفید (الگوی دامنه‌های مجاز)"

#: blackswan-block-external-request.php:715
msgid "e.g. //api.wordpress.org/plugins/"
msgstr "برای مثال: //api.wordpress.org/plugins/"

#: blackswan-block-external-request.php:722
msgid "URL Pattern (whitelisted)"
msgstr "الگوی آدرس (مجاز)"

#: blackswan-block-external-request.php:740
msgid "Browser-side Resources by Domain (JS / CSS)"
msgstr "مسدودسازی ریسورس سمت کاربر (فرانت‌اند) بر اساس لیست سیاه"

#: blackswan-block-external-request.php:744
msgid ""
"When enabled, enqueued JS/CSS from blacklisted domains will be deregistered. Only "
"external resources are affected. Whitelisted patterns are respected."
msgstr ""
"در صورت فعال‌سازی تنظیمات این بخش، فایل‌های JS/CSS بارگذاری‌شده در سمت کاربر (فرانت‌اند) "
"بر اساس لیست دامنه‌های لیست سیاه (از متاباکس بالا ویرایش کنید) حذف می‌شوند. فقط "
"ریسورس‌های خارجی (اکسترنال - از دامنه سایت فعلی بارگیری نشوند) تحت تأثیر این تنظیمات "
"قرار می‌گیرند، همچنین الگوهای لیست سفید نیز رعایت می‌شوند."

#: blackswan-block-external-request.php:749
msgid "Admin Panel (wp-admin)"
msgstr "سمت مدیریت (بک‌اند)"

#: blackswan-block-external-request.php:754
msgid "Public Frontend"
msgstr "سمت کاربر (فرانت‌اند)"

#: blackswan-block-external-request.php:764
msgid "Avatars & Emoji"
msgstr "آواتارها و ایموجی‌ها"

#: blackswan-block-external-request.php:768
msgid ""
"Control WordPress avatar display. When disabled, all avatars (Gravatar and local) "
"are hidden site-wide — preventing outgoing requests to gravatar.com and removing "
"avatar markup from comments, profiles, and admin areas."
msgstr ""
"کنترل نمایش آواتار در وردپرس. وقتی آواتار غیرفعال شود، تمامی آواتارها (از جمله "
"Gravatar و آواتارهای محلی) در سراسر سایت پنهان می‌شوند - این کار از ارسال درخواست‌های "
"خارج از سایت به gravatar.com جلوگیری می‌کند و نشانه‌گذاری برای آواتار را از نظرات، "
"پروفایل‌ها و بخش‌های مدیریت حذف می‌کند."

#: blackswan-block-external-request.php:772
msgid "Disable All Avatars"
msgstr "غیرفعال کردن همه آواتارها"

#: blackswan-block-external-request.php:776
msgid ""
"Block WordPress from loading emoji scripts and stylesheets from external CDN "
"services. This improves performance and privacy by removing unnecessary external "
"requests, while still allowing emojis to display using your system's native emoji "
"support."
msgstr ""
"بارگذاری اسکریپت‌ها و فایل‌های سبک ایموجی از سرویس‌های CDN خارجی را در وردپرس مسدود "
"کنید. این کار با حذف درخواست‌های خارجی غیرضروری، عملکرد و حریم خصوصی را بهبود می‌بخشد "
"و در عین حال همچنان امکان نمایش ایموجی‌ها را با استفاده از پشتیبانی بومی سیستم شما "
"فراهم می‌کند."

#: blackswan-block-external-request.php:780
msgid "Disable All Emoji"
msgstr "غیرفعال کردن تمام ایموجی‌ها"

#: blackswan-block-external-request.php:789
msgid "Block Specific Resources (by URL)"
msgstr "مسدودسازی ریسورس خاص (بر اساس آدرس یا نام)"

#: blackswan-block-external-request.php:793
msgid ""
"Block individual JS or CSS files by matching against their enqueued URL. Full URL, "
"partial path, or even just a filename with extension — anything that appears in the "
"resource URL will match. Works for both local and external resources."
msgstr ""
"مسدودسازی فایل‌های JS یا CSS با تطبیق آدرس بارگذاری‌شده آنها. آدرس کامل، مسیر نسبی، یا "
"حتی فقط نام فایل با پسوند — هر چیزی که در آدرس منبع وجود داشته باشد تطبیق داده "
"می‌شود. برای ریسورس داخلی و خارجی کار می‌کند."

#: blackswan-block-external-request.php:794
#, php-format
msgid "Examples: %s · %s · %s"
msgstr "نمونه‌ها: %s · %s · %s"

#: blackswan-block-external-request.php:796
msgid "Full URL, partial path, or filename.ext"
msgstr "آدرس کامل، مسیر نسبی، یا نام‌فایل.پسوند"

