msgid "Delete All"
msgstr "حذف همه"

#: blackswan-block-external-request.php:362
msgid "Whitelist (Allowed URL Patterns)"
msgstr "فهرست مجاز (الگوی URL های مجاز)"

#: blackswan-block-external-request.php:367
msgid "e.g. //api.wordpress.org/plugins/"
msgstr "برای مثال: //api.wordpress.org/plugins/"

#: blackswan-block-external-request.php:374
msgid "URL Pattern (whitelisted)"
msgstr "الگوی آدرس (مجاز)"

#: blackswan-block-external-request.php:392
msgid "Browser-side Resources by Domain (JS / CSS)"
msgstr "منابع سمت مرورگر بر اساس دامنه (JS / CSS)"

#: blackswan-block-external-request.php:396
msgid ""
"When enabled, enqueued JS/CSS from blacklisted domains will be deregistered. "
"Only external resources are affected. Whitelisted patterns are respected."
msgstr ""
"در صورت فعال‌سازی، فایل‌های JS/CSS بارگذاری‌شده از دامنه‌های فهرست سیاه حذف می‌شوند. "
"فقط منابع خارجی تحت تأثیر قرار می‌گیرند و الگوهای فهرست سفید رعایت می‌شوند."

#: blackswan-block-external-request.php:401
msgid "Admin Panel (wp-admin)"
msgstr "پنل مدیریت (wp-admin)"

#: blackswan-block-external-request.php:406
msgid "Public Frontend"
msgstr "بخش عمومی سایت"

#: blackswan-block-external-request.php:416
msgid "Block Specific Resources (by URL)"
msgstr "مسدودسازی منابع خاص (بر اساس آدرس)"

#: blackswan-block-external-request.php:420
msgid ""
"Block individual JS or CSS files by matching against their enqueued URL. Full "
"URL, partial path, or even just a filename with extension — anything that "
"appears in the resource URL will match. Works for both local and external "
"resources."
msgstr ""
"مسدودسازی فایل‌های JS یا CSS با تطبیق آدرس بارگذاری‌شده آنها. آدرس کامل، مسیر "
"نسبی، یا حتی فقط نام فایل با پسوند — هر چیزی که در آدرس منبع وجود داشته باشد "
"تطبیق داده می‌شود. برای منابع داخلی و خارجی کار می‌کند."

#: blackswan-block-external-request.php:421
#, php-format
msgid "Examples: %s · %s · %s"
msgstr "نمونه‌ها: %s · %s · %s"

#: blackswan-block-external-request.php:423
msgid "Full URL, partial path, or filename.ext"
msgstr "آدرس کامل، مسیر نسبی، یا نام‌فایل.پسوند"

